<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Glow Natural MX - Cosméticos & Bienestar</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <!DOCTYPE html>
    <html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Glow Natural MX - Cosméticos & Bienestar</title>
        <link rel="stylesheet" href="styles.css">
    </head>
    <body>
        <!-- Navbar -->
        <nav class="navbar">
            <div class="container">
                <div class="nav-content">
                    <a href="#" class="logo-link">
                        <img src="logo - png.png" alt="Glow Natural MX" class="logo-img">
                        <span>Glow Natural MX</span>
                    </a>
                    <div class="nav-links">
                        <a href="#" onclick="filterByCategory('todos')">Tienda</a>
                        <a href="#contacto">Contacto</a>
                    </div>
                    <button class="cart-btn" onclick="toggleCart()">
                        🛒 Carrito <span id="cart-count" class="cart-badge">0</span>
                    </button>
                </div>
            </div>
        </nav>

        <!-- Hero Section -->
        <section class="hero" style="background-image: url('data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAQ4AAACUCAMAAABV5TcGAAAAA1BMVEXVAAQrVQ4YAAAAPklEQVR4nO3BMQEAAADCoPVPbQwfoAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAgIcBnKwAAXyxvCsAAAAASUVORK5CYII='); background-size: cover; background-position: center; background-repeat: no-repeat;">
            <div class="hero-content">
                <h1>Tu belleza, nuestra inspiración</h1>
                <p>todo se paga en pesos mexicanos</p>
                <p>Descubre cosméticos, fragancias y productos de bienestar creados con ingredientes naturales</p>
                <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem;">
                    <a href="https://beacons.ai/sebastian233" target="_blank" rel="noopener" class="btn-primary btn-full" style="max-width: 260px; text-align: center;">contactanos</a>
                     <a href="#info-section" target="_blank" rel="noopener" class="btn-primary btn-full" style="max-width: 260px; text-align: center;">¿Quién somos?</a>
                
                </div>
            </div>
        </section>

  

        <!-- Buscador y Filtros -->
        <section class="search-section">
            <div class="container">
                <input type="text" id="search-input" class="search-input" placeholder="Buscar productos...">
                <div class="filters">
                    <button class="filter-btn" data-category="maquillaje" onclick="filterByCategory('maquillaje')">Maquillaje</button>
                    <button class="filter-btn" data-category="cuidado-piel" onclick="filterByCategory('cuidado-piel')">Cuidado de la Piel</button>
                    <button class="filter-btn" data-category="cabello" onclick="filterByCategory('cabello')">Cabello</button>
                    <button class="filter-btn" data-category="bienestar" onclick="filterByCategory('bienestar')">Bienestar</button>
                    <button class="filter-btn" data-category="hombres" onclick="filterByCategory('hombres')">Hombres</button>
                    <button class="filter-btn" data-category="nuevos" onclick="filterByCategory('nuevos')">Nuevos</button>
                    <button class="filter-btn" data-category="descuento" onclick="filterByCategory('descuento')">Descuento</button>
                    <button class="filter-btn" data-category="joyeria" onclick="filterByCategory('joyeria')">Joyería</button>
                </div>
                <div class="filters" style="margin-top: 1rem; gap: .75rem; justify-content: center;">
                <button class="btn-secondary" onclick="resetProductFilter()">Mostrar todo</button>
                </div>
            </div>
        </section>

        <!-- Catálogo de Productos -->
        <section id="productos" class="productos-section">
            <div class="container">
                <h2>Catálogo de productos</h2>
                <div class="producto-controls" style="text-align:center; margin: 1rem 0 2rem;">
      
                </div>
                <div class="productos-grid" id="productos-grid">
                    <!-- Los productos se cargarán aquí dinámicamente -->
                </div>
            </div>
        </section>

        <!-- Carrito Lateral -->
        <div id="cart-sidebar" class="cart-sidebar">
            <div class="cart-header">
                <h3>Tu carrito</h3>
                <button class="close-cart" onclick="toggleCart()">✕</button>
            </div>
            <div class="cart-items" id="cart-items">
                <!-- Items del carrito se mostrarán aquí -->
            </div>
            <div class="cart-footer">
                <div class="cart-total">
                    <span>Total:</span>
                    <span id="cart-total">$0.00</span>
                </div>
                <button class="btn-primary btn-full" onclick="proceedToCheckout()">Proceder al pago</button>
                <button class="btn-secondary btn-full" onclick="toggleCart()">Seguir comprando</button>
                <a class="btn-secondary btn-full" href="https://wa.me/524439331744" target="_blank" rel="noopener">Contáctanos para seguir tu pedido con exito manda captura de tu pedido esta sitio web esta en mantenimento: +52 443 933 1744</a>
            </div>
        </div>

        <!-- Modal de Detalles del Producto -->
        <div id="product-modal" class="modal">
            <div class="modal-content modal-producto">
                <button class="close-modal" onclick="closeProductModal()">✕</button>
            
                <div class="producto-detalle-container">
                    <!-- Galería de imágenes -->
                    <div class="producto-galeria">
                        <div class="imagen-principal" id="imagen-principal">
                            <div style="font-size: 5rem; display: flex; align-items: center; justify-content: center; height: 100%;">💄</div>
                        </div>
                        <div class="imagenes-miniaturas" id="imagenes-miniaturas">
                            <!-- Se llenarán dinámicamente -->
                        </div>
                    </div>

                    <!-- Información del producto -->
                    <div class="producto-detalles">
                        <div class="producto-categoria" id="modal-categoria">Categoría</div>
                        <h1 id="modal-nombre">Nombre del Producto</h1>
                    
                        <div class="producto-rating" style="margin-bottom: 1rem;">
                            <span id="modal-rating">⭐ 4.7</span>
                            <span id="modal-reviews">(244 reseñas)</span>
                        </div>

                        <div class="producto-precio-seccion">
                            <span id="modal-precio-original" class="producto-precio-original"></span>
                            <span id="modal-precio" class="producto-precio">$24.99</span>
                        </div>

                        <div id="modal-badge" class="badge-modal"></div>

                        <p id="modal-descripcion-larga" class="descripcion-larga">
                            Descripción del producto
                        </p>

                        <div class="caracteristicas-section">
                            <h3>Características</h3>
                            <ul id="modal-caracteristicas" class="caracteristicas-list">
                                <!-- Se llenará dinámicamente -->
                            </ul>
                        </div>

                        <div class="cantidad-selector">
                            <label>Cantidad:</label>
                            <div class="cantidad-input">
                                <button onclick="decrementarCantidad()">−</button>
                                <input type="number" id="cantidad-modal" value="1" min="1" readonly>
                                <button onclick="incrementarCantidad()">+</button>
                            </div>
                        </div>

                        <button class="btn-primary btn-full" style="margin-top: 1.5rem;" id="btn-agregar-modal" onclick="agregarAlCarritoDesdeModal()">
                            Agregar al carrito - <span id="precio-total-modal">24.99</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modal de Checkout -->
        <div id="checkout-modal" class="modal">
            <div class="modal-content">
                <button class="close-modal" onclick="closeCheckout()">✕</button>
                <h2>Pagar pedido</h2>
            
                <form id="checkout-form" onsubmit="submitOrder(event)">
                    <div class="form-group">
                        <label for="email">Correo electrónico</label>
                        <input type="email" id="email" required>
                    </div>

                    <div class="form-group">
                        <label for="address">Dirección de envío</label>
                        <input type="text" id="address" placeholder="Calle, número, ciudad" required>
                    </div>

                    <div class="form-group">
                        <label>Método de pago</label>
                        <div class="payment-methods">
                            <label class="payment-option">
                                <input type="radio" name="payment" value="stripe" checked>
                                <span>💳 Tarjeta</span>
                            </label>
                            <label class="payment-option">
                                <input type="radio" name="payment" value="paypal">
                                <span>🅿️ PayPal</span>
                            </label>
                            <label class="payment-option">
                                <input type="radio" name="payment" value="mercadopago">
                                <span>💰 Mercado Pago</span>
                            </label>
                        </div>
                    </div>

                    <div id="card-fields" class="form-group">
                        <label for="card-number">Número de tarjeta</label>
                        <input type="text" id="card-number" placeholder="4242 4242 4242 4242" maxlength="19">
                        <div class="form-row">
                            <input type="text" id="card-expiry" placeholder="MM/AA" maxlength="5">
                            <input type="text" id="card-cvc" placeholder="CVC" maxlength="3">
                        </div>
                    </div>

                    <div class="order-summary">
                        <h3>Resumen del pedido</h3>
                        <div id="order-items">
                            <!-- Items del pedido se mostrarán aquí -->
                        </div>
                        <div class="summary-total">
                            <span>Total a pagar:</span>
                            <span id="order-total">$0.00</span>
                        </div>
                    </div>

                    <button type="submit" class="btn-primary btn-full">Pagar <span id="pay-amount">$0.00</span></button>
                </form>
            </div>
        </div>

        <!-- Overlay para modal -->
        <div id="modal-overlay" class="modal-overlay" onclick="closeCheckout()"></div>



        <!-- Sección de Videos -->
        <section class="videos-section">
            <div class="container">
                <h2>Descubre nuestros productos en acción</h2>
                <p class="videos-subtitle">Mira reseñas y tutoriales de nuestros productos de belleza</p>
            
                <div class="videos-grid">





                    <!-- Video 1 -->
                   <div class="video-card">
        <div class="video-container">
            <!-- Se actualizó el enlace del video y se cambió /watch por /embed para que sea compatible con iframe -->
            <iframe src="https://www.youtube.com/embed/3XIEqC4OB78?si=v2LKpJN2nBHcRSfc" title="Reseña de cuidado de piel" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
        </div> 
        <h3>¡La belleza y el bienestar!</h3>
        <p>Descubre quiénes somos y cuál es nuestra misión en la industria de la belleza natural</p>
    </div>
                    <!-- Video 2 -->
                    <div class="video-card">
                        <div class="video-container">
                            <iframe src="https://www.youtube.com/embed/28fu48MalQk" title="Reseña de cuidado de piel" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                        </div>
                        <h3>¡Conócenos!</h3>
                        <p>Descubre quiénes somos y cuál es nuestra misión en la industria de la belleza natural</p>
                    </div>
                    </div>
                    </div>
                </div>
            </div>
        </section>

























        <!-- Sección de información personalizada -->
        <section id="info-section" class="info-section" style="padding: 3rem 0; background: #f9f2f7;">
            <div class="container">
                <div style="max-width: 780px; margin: 0 auto; text-align: center;">
                    <h2><p>¿Quien somos?</p>
                    </div></h2>
                    <div style="margin: 1.5rem auto; width: 60px; height: 60px; display: flex; align-items: center; justify-content: center;">
                        <h2><p>¿Quien somos?</p>
                        <img src="contentImage.jpg" alt="imagen principal" width="300" height="300" style="border-radius: 50%; object-fit: cover;">
                    </div>
                    <p style="margin: 1rem auto 1.5rem; color: #444; line-height: 1.8;">Coloca aquí detalles sobre el mantenimiento de la página, opciones de contacto, envíos, promociones o cualquier mensaje adicional que quieras compartir con tus clientes.</p>
                    <p style="margin: 0.5rem auto; color: #444;">Puedes editar este texto directamente en el archivo <strong>index.html</strong> para personalizarlo como quieras.</p>
                    <div style="margin: 2rem auto; max-width: 560px;">
                        <a href="https://ferja.mx" target="_blank" rel="noopener" class="btn-primary btn-full" style="max-width: 260px; margin-top: 1rem; text-align: center;">Ver más detalles en mi sitio</a>
                    </div>
                </div>
            </div>
        </section>











        <!-- Footer -->
        <footer id="contacto" class="footer">
            <div class="container">
                <div class="footer-content">
                    <div class="footer-section">
                        <h3>💄 Belleza Natural</h3>
                        <p>Cosméticos y bienestar inspirados en la naturaleza. Productos con ingredientes seguros, veganos y libres de crueldad animal.</p>
                    </div>
                    <div class="footer-section">
                        <h4>Tienda</h4>
                        <ul>
                            <li><a href="#" onclick="filterByCategory('maquillaje')">Maquillaje</a></li>
                            <li><a href="#" onclick="filterByCategory('cuidado-piel')">Cuidado de la Piel</a></li>
